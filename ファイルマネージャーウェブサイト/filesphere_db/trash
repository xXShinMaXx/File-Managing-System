CREATE TABLE trash (

    id INT AUTO_INCREMENT PRIMARY KEY,

    file_id INT,

    user_id INT,

    deleted_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    expires_at TIMESTAMP NULL,

    FOREIGN KEY(file_id)
        REFERENCES files(id)
        ON DELETE CASCADE,

    FOREIGN KEY(user_id)
        REFERENCES users(id)
        ON DELETE CASCADE

);